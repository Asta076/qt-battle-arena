    // Stats
    m_statsLabel = new QLabel("Stats:", this);
    m_statsLabel->setAlignment(Qt::AlignCenter);

    // Inventory
    m_inventoryLabel = new QLabel("Inventory:", this);
    m_inventoryLabel->setAlignment(Qt::AlignCenter);

